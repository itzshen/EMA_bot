# Discord incoming webhook URL (required unless DRY_RUN=1)
DISCORD_WEBHOOK_URL=

# Symbol must match MT5 Market Watch exactly (e.g. US100Cash, US100, NAS100)
SYMBOL=US100Cash

# H4 EMA210 trend: compare last closed H4 vs N bars back (6 ≈ 24h of H4 candles)
H4_TREND_BARS=6

# Optional: MT5 login if not already logged in via terminal
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Optional: path to terminal64.exe if MetaTrader5.initialize() cannot find MT5
MT5_PATH=

# Set to 1 to log alerts without POSTing to Discord
DRY_RUN=0
